# Local/high-memory semantic mode. Install requirements.txt before using this profile.
APP_ENV=development
SONICMIND_MODE=local_semantic
SONICMIND_RETRIEVAL_BACKEND=faiss
ENABLE_LOCAL_EMBEDDING_MODEL=true
ENABLE_RERANKER=true
RAG_LOAD_ON_STARTUP=false
RAG_TOP_K=5
RAG_CANDIDATE_K=25
MAX_CONTEXT_CHARS=12000
MAX_SOURCE_CHARS=4000
RAG_FALLBACK_MODE=error

# Keep native libraries conservative unless you have measured more headroom.
WEB_CONCURRENCY=1
MALLOC_ARENA_MAX=2
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
PYTHONUNBUFFERED=1

# Private values belong in .env.local.semantic or .env, not this example file.
DATABASE_URL=postgresql://...
BACKEND_SECRET_KEY=replace_me
OPENAI_API_KEY=replace_me
LLM_API_KEY=replace_me
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=replace_me
SPOTIFY_CLIENT_ID=replace_me
SPOTIFY_CLIENT_SECRET=replace_me
DISCOGS_USER_TOKEN=replace_me
