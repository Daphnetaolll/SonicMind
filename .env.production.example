# Production lightweight mode for Render 2 GB backend.
APP_ENV=production
SONICMIND_MODE=production_light
SONICMIND_RETRIEVAL_BACKEND=lexical
ENABLE_LOCAL_EMBEDDING_MODEL=false
ENABLE_RERANKER=false
RAG_LOAD_ON_STARTUP=false
RAG_TOP_K=3
RAG_CANDIDATE_K=12
MAX_CONTEXT_CHARS=6000
MAX_SOURCE_CHARS=2000
RAG_FALLBACK_MODE=keyword

# Process and native-library limits keep one web worker from multiplying memory use.
WEB_CONCURRENCY=1
MALLOC_ARENA_MAX=2
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
PYTHONUNBUFFERED=1

# Replace placeholders only in Render or a private local env file, never in Git.
DATABASE_URL=postgresql://...
BACKEND_SECRET_KEY=replace_me
OPENAI_API_KEY=replace_me
LLM_API_KEY=replace_me
BACKEND_CORS_ORIGINS=https://sonicmind.onrender.com
FRONTEND_BASE_URL=https://sonicmind.onrender.com
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=replace_me
SPOTIFY_CLIENT_ID=replace_me
SPOTIFY_CLIENT_SECRET=replace_me
DISCOGS_USER_TOKEN=replace_me
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
STRIPE_CREATOR_PRICE_ID=price_replace_me
STRIPE_PRO_PRICE_ID=price_replace_me
SONICMIND_ENABLE_DEMO_BILLING_ROLLOVER=false
