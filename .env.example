# Required: at least one of these API keys must be set.
LLM_API_KEY=your_llm_api_key_here
OPENAI_API_KEY=

# Optional: override the default model/base URL.
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
SSL_CERT_FILE=/absolute/path/to/your/venv/lib/python3.13/site-packages/certifi/cacert.pem

# Required for deployed FastAPI auth tokens. Use a long random value in production.
BACKEND_SECRET_KEY=replace_with_a_long_random_backend_secret

# Optional: comma-separated frontend origins allowed to call the FastAPI backend.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Required for auth/subscription/quota storage.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_agent_web

# Optional until billing is enabled: Stripe test/live credentials stay backend-only.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CREATOR_PRICE_ID=price_replace_creator_monthly
STRIPE_PRO_PRICE_ID=price_replace_pro_monthly
FRONTEND_BASE_URL=http://localhost:5173
SONICMIND_ENABLE_DEMO_BILLING_ROLLOVER=true

# Optional: tune LLM request behavior.
LLM_TIMEOUT=60
LLM_TEMPERATURE=0.2

# Optional: formal web search provider for hybrid RAG.
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_TOPIC=general
TAVILY_INCLUDE_RAW_CONTENT=false
TAVILY_CHUNKS_PER_SOURCE=3
BRAVE_SEARCH_API_KEY=
WEB_SEARCH_COUNTRY=us
WEB_SEARCH_LANG=en
WEB_SEARCH_SAFESEARCH=moderate
WEB_FETCH_RESULT_PAGES=false
EXTERNAL_FETCH_TIMEOUT=12
MUSIC_METADATA_USER_AGENT=sonicmind/0.1 (your-contact@example.com)
DISCOGS_USER_TOKEN=

# Optional: keep production RAG inside small-memory web services.
APP_ENV=development
SONICMIND_MODE=production_light
SONICMIND_RETRIEVAL_BACKEND=lexical
SONICMIND_MEMORY_LOGS=true
RAG_TOP_K=3
RAG_CANDIDATE_K=12
MAX_CONTEXT_CHARS=6000
MAX_SOURCE_CHARS=2000
ENABLE_RERANKER=false
ENABLE_LOCAL_EMBEDDING_MODEL=false
RAG_LOAD_ON_STARTUP=false
RAG_FALLBACK_MODE=keyword
WEB_CONCURRENCY=1
MALLOC_ARENA_MAX=2
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
PYTHONUNBUFFERED=1

# Optional: Spotify recommendations.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: allow local-only seed users for testing Free/Creator/Pro behavior.
SONICMIND_ENABLE_DEV_SEEDS=false
SONICMIND_DEV_SEED_PASSWORD=Test123456!
